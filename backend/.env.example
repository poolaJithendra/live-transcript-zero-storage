DEEPGRAM_API_KEY=your_deepgram_key_here
# Comma-separated origins that can call the backend.
# Include your Vercel production domain before deploy.
ALLOWED_ORIGIN=http://127.0.0.1:5500,https://your-app.vercel.app
TRUSTED_HOSTS=localhost,127.0.0.1,your-backend.up.railway.app
SESSION_TTL_MINUTES=240
RESUME_UPLOAD_MAX_MB=8
SESSION_CREATE_RATE_LIMIT_PER_MINUTE=60

# Recommended for cloud deploy (Railway backend + Vercel frontend).
PRACTICE_AI_PROVIDER=azure
PRACTICE_AI_MODEL=gpt-4.1
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Optional local model fallback.
PRACTICE_AI_FALLBACK_MODELS=llama3:latest,llama3.2:3b,qwen2.5:7b,gemma3:4b
PRACTICE_AI_BASE_URL=http://127.0.0.1:11434/v1
